{
  "name": "arra-desktop",
  "version": "1.0.0",
  "description": "Arra — приёмник файлов на ПК (телефон → папка → буфер обмена)",
  "main": "main.js",
  "author": "Arra",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^33.2.0"
  },
  "dependencies": {
    "@electron/rebuild": "^4.0.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0",
    "ws": "^8.18.0"
  },
  "build": {
    "appId": "com.arratima.arra.desktop",
    "productName": "Arra",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
